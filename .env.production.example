# Production — veridian.furkanguven.space
# Copy to .env on the server: cp .env.production.example .env

NODE_ENV=production
APP_NAME=veridian
APP_URL=https://veridian.furkanguven.space
API_URL=https://api.veridian.furkanguven.space

# Frontend
NEXT_PUBLIC_API_URL=https://api.veridian.furkanguven.space
NEXT_PUBLIC_WS_URL=wss://api.veridian.furkanguven.space
# SSR (Next.js server → API on same host)
API_INTERNAL_URL=http://127.0.0.1:8000

# Backend API
API_HOST=127.0.0.1
API_PORT=8000
API_DEBUG=false
API_CORS_ORIGINS=https://veridian.furkanguven.space

# JWT — CHANGE THIS
JWT_SECRET=generate-a-long-random-secret-here

# OAuth callbacks (update when enabling auth)
GOOGLE_REDIRECT_URI=https://api.veridian.furkanguven.space/api/v1/auth/google/callback
GITHUB_REDIRECT_URI=https://api.veridian.furkanguven.space/api/v1/auth/github/callback

# Host PostgreSQL & Redis
DATABASE_URL=postgresql+asyncpg://veridian:veridian@localhost:5432/veridian
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=amqp://veridian:veridian@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# MinIO
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=veridian

HEALTH_CHECK_INFRA=true
RATE_LIMIT_ENABLED=true
