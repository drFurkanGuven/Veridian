# Production — veridian.furkanguven.space
# Copy to .env on the server: cp .env.production.example .env

NODE_ENV=production
APP_NAME=veridian
APP_URL=https://veridian.furkanguven.space
API_URL=https://api.veridian.furkanguven.space
NEXT_PUBLIC_API_URL=https://api.veridian.furkanguven.space
NEXT_PUBLIC_WS_URL=wss://api.veridian.furkanguven.space
# SSR (Next.js server → API on same host)
API_INTERNAL_URL=http://127.0.0.1:8000

# Backend API
API_HOST=127.0.0.1
API_PORT=8000
API_DEBUG=false
API_CORS_ORIGINS=https://veridian.furkanguven.space

# JWT — üret: openssl rand -hex 32
JWT_SECRET=BURAYA_OPENSSL_ILE_URETILMIS_UZUN_SECRET

# Admin bootstrap (virgülle ayrılmış e-postalar)
ADMIN_EMAILS=senin@email.com
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

# Google OAuth
# Redirect URI: https://veridian.furkanguven.space/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — https://github.com/settings/developers
# Callback URL: https://veridian.furkanguven.space/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Host PostgreSQL & Redis
DATABASE_URL=postgresql+asyncpg://veridian:veridian@localhost:5432/veridian
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=amqp://veridian:veridian@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# MinIO
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=veridian

HEALTH_CHECK_INFRA=true
RATE_LIMIT_ENABLED=true

# AI assistant (OpenAI)
OPENAI_API_KEY=
AI_MODEL=gpt-4o
AI_MAX_CONTEXT_TOKENS=32000
RATE_LIMIT_AI_REQUESTS_PER_MINUTE=20
