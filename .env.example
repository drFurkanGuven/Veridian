# =============================================================================
# Veridian — Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_NAME=veridian
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Frontend (apps/web)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# -----------------------------------------------------------------------------
# Backend API (apps/api)
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true
API_CORS_ORIGINS=http://localhost:3000

# JWT
JWT_SECRET=change-me-to-a-random-64-char-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Account security
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
AUTH_MIN_PASSWORD_LENGTH=8
ADMIN_EMAILS=you@example.com

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=veridian
POSTGRES_PASSWORD=veridian
POSTGRES_DB=veridian
DATABASE_URL=postgresql+asyncpg://veridian:veridian@localhost:5432/veridian

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# RabbitMQ (Celery broker)
# -----------------------------------------------------------------------------
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=veridian
RABBITMQ_PASSWORD=veridian
CELERY_BROKER_URL=amqp://veridian:veridian@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# -----------------------------------------------------------------------------
# Object Storage (MinIO locally, S3 in production)
# -----------------------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=veridian
S3_REGION=us-east-1
S3_USE_SSL=false

# -----------------------------------------------------------------------------
# Health Checks
# -----------------------------------------------------------------------------
HEALTH_CHECK_INFRA=true

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_AI_REQUESTS_PER_MINUTE=20

# -----------------------------------------------------------------------------
# AI Assistant
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
AI_MODEL=gpt-4o
AI_MAX_CONTEXT_TOKENS=32000

# -----------------------------------------------------------------------------
# Worker Sandbox
# -----------------------------------------------------------------------------
WORKER_DOCKER_SOCKET=/var/run/docker.sock
WORKER_MEMORY_LIMIT=2g
WORKER_CPU_LIMIT=2
WORKER_NETWORK_MODE=none
